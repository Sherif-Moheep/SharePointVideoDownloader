{
  "manifest_version": 3,
  "name": "SharePoint Video Downloader",
  "version": "1.0",
  "key": "",
  "permissions": [
    "webRequest",
    "tabs",
    "scripting",
    "activeTab",
    "nativeMessaging",
    "storage"
  ],
  "host_permissions": [
    "*://*.sharepoint.com/*",
    "*://*.svc.ms/*",         
    "*://*.microsoftstream.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "images/logo-16-color.png",
    "32": "images/logo-32-color.png",
    "48": "images/logo-48-color.png",
    "128": "images/logo-128-color.png"
  },
  "action": {
    "default_title": "SharePoint Video Downloader",
    "default_icon": {
      "16": "images/logo-16-gray.png",
      "32": "images/logo-32-gray.png",
      "48": "images/logo-48-gray.png",
      "128": "images/logo-128-gray.png"
    }
  }
}