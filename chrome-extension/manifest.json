{
  "manifest_version": 3,
  "name": "SharePoint Video Downloader",
  "version": "1.0",
  "permissions": [
    "webRequest",
    "tabs"
  ],
  "host_permissions": [
    "*://*.sharepoint.com/*",
    "*://*.svc.ms/*",         
    "*://*.microsoftstream.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "images/logo-16.png",
    "32": "images/logo-32.png",
    "34": "images/logo-34.png",
    "48": "images/logo-48.png",
    "128": "images/logo-128.png"
  },
  "action": {
    "default_title": "SharePoint Video Downloader",
    "default_icon": {
      "16": "images/logo-16.png",
      "32": "images/logo-32.png",
      "34": "images/logo-34.png",
      "48": "images/logo-48.png",
      "128": "images/logo-128.png"
    }
  }
}